{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "../build",
    "distDir": "../build"
  },
  "package": {
    "productName": "supa-bass-o-matic",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "deb": {
        "depends": [
          "webkit2gtk-4.0 (>= 2.36)",
          "libwebkit2gtk-4.0-37 (>= 2.36)",
          "libjavascriptcoregtk-4.0-18 (>= 2.36)",
          "libgtk-3-0 (>= 3.24)",
          "librsvg2-2 (>= 2.50)",
          "libsoup2.4-1 (>= 2.74)",
          "libayatana-appindicator3-1",
          "libicu70",
          "libc6 (>= 2.35)"
        ]
      },
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/icon.svg"
      ],
      "identifier": "com.supabasecommunity.supabassomatic",
      "targets": ["deb", "appimage"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Supa Bass-O-Matic",
        "width": 800
      }
    ]
  }
}
